{
  "name": "quorum-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "1.6.14",
    "better-sqlite3": "^12.10.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "pnpm": {
    "overrides": {
      "better-call": "2.0.3",
      "kysely": "0.28.17"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
