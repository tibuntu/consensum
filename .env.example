# Database
DATABASE_URL="file:./data/app.db"
# better-auth / app
AUTH_SECRET="change-me-to-a-32+char-random-string"
BASE_URL="http://localhost:3000"
# Extra CSRF-trusted origins beyond BASE_URL (comma-separated).
TRUSTED_ORIGINS=
# Set "true" to disable auth rate limiting (test/dev only).
# DISABLE_RATE_LIMIT=
# Email (optional; absence disables email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=
# Coalescing window for activity digests, ms (default 45000).
EMAIL_DEBOUNCE_MS=
# EMAIL_TRANSPORT=json   # test-only capture transport
# Outbound webhooks
# App key that encrypts stored webhook signing secrets at rest (AES-256-GCM).
# Recommended in production; if unset, secrets are stored plaintext so dev/CI runs keyless.
WEBHOOK_SECRET_KEY=
# Dev-only: allow http/loopback/link-local webhook targets (prod requires https + blocks internal).
# WEBHOOK_ALLOW_INSECURE=
# Outbox worker (durable async delivery — email digests + webhook deliveries)
# Auto-starts in dev/prod; off under NODE_ENV=test. Override either way:
#   "true"/"1" force-on, "false" force-off.
OUTBOX_WORKER_AUTOSTART=
# Polling interval for due jobs, ms (default 5000).
OUTBOX_POLL_MS=
# Retry backoff delays as comma-separated ms (default 60000,300000,1800000,7200000,21600000 = 1m,5m,30m,2h,6h).
OUTBOX_BACKOFF_MS=
# Per-job max attempts before a job is dead-lettered (default 6).
OUTBOX_MAX_ATTEMPTS=
# Max jobs leased per worker tick (default 25).
OUTBOX_BATCH=
# Registration allowlist (fail-closed). Comma-separated entries; each is either an exact
# email (alice@corp.com), a bare domain (corp.com = anyone @corp.com), or "*" to allow ALL
# emails (open registration).
# UNSET OR EMPTY = self-service registration is DISABLED. List at least your own
# email/domain to allow the first account, or "*" to allow everyone.
REGISTRATION_ALLOWLIST=
# Optional SSO (generic OIDC). Unset = password-only login.
# When all three are set, self-service password signup is disabled (existing
# password LOGIN still works); set NEXT_PUBLIC_OIDC_ENABLED=true to show the button.
# Set NEXT_PUBLIC_OIDC_ENABLED=true ONLY together with the three OIDC_* vars — the
# public flag only controls the button; setting it alone shows a button that 404s.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
NEXT_PUBLIC_OIDC_ENABLED=
# Document editing UI (optional). Default: enabled.
# Set to "false" to hide the in-app Edit button (plans stay agent-driven via the API).
# The PATCH /api/documents/[id] edit endpoint is NOT gated — only the UI.
EDIT_UI_ENABLED=
