{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests"
  ],
  "prFooter": "",
  "semanticCommits": "enabled",
  "semanticCommitType": "fix",
  "packageRules": [
    {
      "description": "Group all devDependency updates into a single PR to minimise tooling churn.",
      "matchDepTypes": ["devDependencies"],
      "groupName": "dev dependencies"
    },
    {
      "description": "Auto-merge non-major updates once required CI checks pass. Major bumps still require manual review.",
      "matchUpdateTypes": ["minor", "patch", "digest", "pin", "pinDigest", "lockFileMaintenance"],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
