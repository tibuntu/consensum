generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  role          String?   @default("member")
  emailNotifications Boolean @default(true)
  sessions      Session[]
  accounts      Account[]
  apiTokens        ApiToken[]
  ownedDocuments   Document[]        @relation("DocumentOwner")
  authoredVersions DocumentVersion[]
  annotations      Annotation[]
  comments         Comment[]
  reviews          Review[]
  notifications    Notification[]
  documentParticipations DocumentParticipant[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@unique([accountId, providerId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime

  @@index([identifier])
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  label      String
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  scopes     String    @default("plans:write,feedback:read")

  @@index([userId])
}

model Document {
  id                String           @id @default(cuid())
  title             String
  ownerId           String
  owner             User             @relation("DocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  state             String           @default("DRAFT")
  requiredApprovals Int              @default(1)
  source            String           @default("WEB")
  agentContext      String?
  currentVersionId  String?          @unique
  currentVersion    DocumentVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  versions          DocumentVersion[] @relation("DocumentVersions")
  annotations       Annotation[]
  reviews           Review[]
  notifications     Notification[]
  participants      DocumentParticipant[]

  @@index([ownerId])
  @@index([state])
}

model DocumentVersion {
  id            String   @id @default(cuid())
  documentId    String
  document      Document @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  versionNumber Int
  markdown      String
  contentHash   String
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  currentFor         Document?    @relation("CurrentVersion")
  annotationsCreated Annotation[] @relation("AnnotationVersion")
  reviewsOn          Review[]     @relation("ReviewVersion")

  @@unique([documentId, versionNumber])
  @@index([documentId])
}

model Annotation {
  id                 String   @id @default(cuid())
  documentId         String
  document           Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdOnVersionId String
  createdOnVersion   DocumentVersion @relation("AnnotationVersion", fields: [createdOnVersionId], references: [id], onDelete: Restrict)
  kind               String   @default("COMMENT")
  anchorExact        String?
  anchorPrefix       String?
  anchorSuffix       String?
  startOffset        Int?
  endOffset          Int?
  status             String   @default("ACTIVE")
  threadStatus       String   @default("OPEN")
  authorId           String
  author             User     @relation(fields: [authorId], references: [id])
  createdAt          DateTime @default(now())
  comments           Comment[]

  @@index([documentId])
  @@index([createdOnVersionId])
}

model Comment {
  id           String     @id @default(cuid())
  annotationId String
  annotation   Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation(fields: [authorId], references: [id])
  body         String
  createdAt    DateTime   @default(now())

  @@index([annotationId])
}

model Review {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reviewerId  String
  reviewer    User     @relation(fields: [reviewerId], references: [id])
  verdict     String
  onVersionId String
  onVersion   DocumentVersion @relation("ReviewVersion", fields: [onVersionId], references: [id], onDelete: Restrict)
  dismissed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([documentId])
  @@index([onVersionId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  type       String
  actorId    String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, read])
  @@index([documentId])
}

model DocumentParticipant {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([documentId, userId])
  @@index([userId])
}
